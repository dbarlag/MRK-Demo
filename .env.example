# Okta OIDC
OKTA_ISSUER=https://your-org.okta.com/oauth2/default
OKTA_CLIENT_ID=your-client-id
OKTA_CLIENT_SECRET=your-client-secret

# NextAuth
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# Vakt API (frivillig.rodekors.no) - prefix "main" for full data incl. users
VAKT_API_URL=https://frivillig.rodekors.no
VAKT_API_PREFIX=main
VAKT_STATS_TOKEN=your-vakt-bearer-token

# Backend API (for future use)
BACKEND_URL=https://api.rodekors.no
BACKEND_API_KEY=
